@@ -0,0 +1,322 @@
+// Regression tests for the prompt-classification heuristics in classifier.mjs.
+// Run with: node --test .github/extensions/model-router/classifier.test.mjs
+
+import { describe, it } from "node:test";
+import assert from "node:assert/strict";
+import {
+  normalizePrompt,
+  matchesPattern,
+  isExplicitReviewRequest,
+  isToolHeavy,
+  isComplexOrchestration,
+  classifyPrompt,
+} from "./classifier.mjs";
+
+// ---------------------------------------------------------------------------
+// normalizePrompt
+// ---------------------------------------------------------------------------
+describe("normalizePrompt", () => {
+  it("lowercases input", () => {
+    assert.equal(normalizePrompt("Hello World"), "hello world");
+  });
+
+  it("coerces non-string gracefully", () => {
+    assert.equal(normalizePrompt(null), "");
+    assert.equal(normalizePrompt(undefined), "");
+    assert.equal(normalizePrompt(42), "42");
+  });
+});
+
+// ---------------------------------------------------------------------------
+// matchesPattern — word-boundary accuracy
+// ---------------------------------------------------------------------------
+describe("matchesPattern (word boundaries)", () => {
+  it("matches a standalone keyword", () => {
+    assert.ok(matchesPattern("please fix the bug", "fix"));
+  });
+
+  it('does NOT match "fix" inside "prefix"', () => {
+    assert.ok(!matchesPattern("prefix this value", "fix"));
+  });
+
+  it('does NOT match "call" inside "callback"', () => {
+    assert.ok(!matchesPattern("register a callback here", "call"));
+  });
+
+  it('does NOT match "run" inside "return"', () => {
+    assert.ok(!matchesPattern("make it return early", "run"));
+  });
+
+  it("multi-word phrases use substring matching (no boundary requirement)", () => {
+    assert.ok(matchesPattern("find bugs in the codebase", "find bugs"));
+  });
+
+  it("multi-word phrase: negative when absent", () => {
+    assert.ok(!matchesPattern("find all functions", "find bugs"));
+  });
+});
+
+// ---------------------------------------------------------------------------
+// isExplicitReviewRequest
+// ---------------------------------------------------------------------------
+describe("isExplicitReviewRequest", () => {
+  const positive = [
+    "please review this PR",
+    "Can you do a code review of my changes?",
+    "Review the code in src/auth.ts",
+    "audit the authentication module",
+    "check approval readiness before merging",
+    "approve this pull request",
+    "PR review needed",
+    "find bugs in the payment service",
+    "bug finding session on the new feature",
+    "regression hunting after the deploy",
+    "regression hunt before release",
+    "find regressions introduced in v2",
+  ];
+
+  for (const prompt of positive) {
+    it(`detects explicit review: "${prompt.slice(0, 60)}"`, () => {
+      assert.ok(
+        isExplicitReviewRequest(normalizePrompt(prompt)),
+        `Expected review detection for: ${prompt}`,
+      );
+    });
+  }
+
+  const negative = [
+    "implement the new login flow",
+    "update the README",
+    "debug the crash in production",
+    "write a plan for the migration",
+    "explain how the router works",
+    // "review" must not trigger on unrelated word-boundary neighbors:
+    "I need to preview the changes",
+    // "fix" alone is debugging, not review:
+    "fix the null pointer exception",
+  ];
+
+  for (const prompt of negative) {
+    it(`does NOT flag as review: "${prompt.slice(0, 60)}"`, () => {
+      assert.ok(
+        !isExplicitReviewRequest(normalizePrompt(prompt)),
+        `Unexpected review detection for: ${prompt}`,
+      );
+    });
+  }
+});
+
+// ---------------------------------------------------------------------------
+// isToolHeavy
+// ---------------------------------------------------------------------------
+describe("isToolHeavy", () => {
+  it("detects bash keyword", () => {
+    assert.ok(isToolHeavy("run the bash script to deploy"));
+  });
+
+  it("detects curl", () => {
+    assert.ok(isToolHeavy("use curl to hit the endpoint"));
+  });
+
+  it("detects api (case-insensitive via normalizePrompt)", () => {
+    assert.ok(isToolHeavy(normalizePrompt("call the REST API")));
+  });
+
+  it("detects agent keyword", () => {
+    assert.ok(isToolHeavy("launch an agent to scrape the page"));
+  });
+
+  it("is false for pure prose", () => {
+    assert.ok(!isToolHeavy("explain what dependency injection means"));
+  });
+});
+
+// ---------------------------------------------------------------------------
+// isComplexOrchestration
+// ---------------------------------------------------------------------------
+describe("isComplexOrchestration", () => {
+  const positive = [
+    "run parallel agents to process each file",
+    "coordinate multiple agents for the migration",
+    "use a multi-agent setup to handle the pipeline",
+    "orchestrate the deployment across regions",
+    "set up orchestration for the CI workflow",
+    "use parallel tools to speed up the analysis",
+    "build a tool chain that clones then tests then deploys",
+    "chained tools across the pipeline stages",
+  ];
+
+  for (const prompt of positive) {
+    it(`detects orchestration: "${prompt.slice(0, 60)}"`, () => {
+      assert.ok(
+        isComplexOrchestration(normalizePrompt(prompt)),
+        `Expected orchestration for: ${prompt}`,
+      );
+    });
+  }
+
+  const negative = [
+    "implement a simple REST endpoint",
+    "write unit tests for the auth module",
+    "refactor the login function",
+    "run the test suite",
+  ];
+
+  for (const prompt of negative) {
+    it(`does NOT flag as orchestration: "${prompt.slice(0, 60)}"`, () => {
+      assert.ok(
+        !isComplexOrchestration(normalizePrompt(prompt)),
+        `Unexpected orchestration for: ${prompt}`,
+      );
+    });
+  }
+});
+
+// ---------------------------------------------------------------------------
+// classifyPrompt — explicit review → reasoning tier
+// ---------------------------------------------------------------------------
+describe("classifyPrompt: explicit review detection", () => {
+  it("review keyword → kind=review, tier=reasoning", () => {
+    const r = classifyPrompt("Please review this PR before merging");
+    assert.equal(r.kind, "review");
+    assert.equal(r.tier, "reasoning");
+  });
+
+  it("audit keyword → kind=review, tier=reasoning", () => {
+    const r = classifyPrompt("Audit the security module for vulnerabilities");
+    assert.equal(r.kind, "review");
+    assert.equal(r.tier, "reasoning");
+  });
+
+  it("find bugs → kind=review, tier=reasoning", () => {
+    const r = classifyPrompt("Find bugs in the new payment flow");
+    assert.equal(r.kind, "review");
+    assert.equal(r.tier, "reasoning");
+  });
+
+  it("regression hunt → kind=review, tier=reasoning", () => {
+    const r = classifyPrompt("Do a regression hunt across the last three releases");
+    assert.equal(r.kind, "review");
+    assert.equal(r.tier, "reasoning");
+  });
+
+  it("review beats implement keyword — review wins", () => {
+    // A prompt that has both "implement" and "review" should still route to review
+    const r = classifyPrompt("implement and review the auth module");
+    assert.equal(r.kind, "review");
+    assert.equal(r.tier, "reasoning");
+  });
+});
+
+// ---------------------------------------------------------------------------
+// classifyPrompt — tool-heavy implementation → builder tier
+// ---------------------------------------------------------------------------
+describe("classifyPrompt: tool-heavy implementation routing", () => {
+  it("simple implement → builder (default)", () => {
+    const r = classifyPrompt("implement the user registration endpoint");
+    assert.equal(r.kind, "implementation");
+    assert.equal(r.tier, "builder");
+  });
+
+  it("implement + bash → builder, toolHeavy=true", () => {
+    const r = classifyPrompt("implement a bash script that backs up the database");
+    assert.equal(r.kind, "implementation");
+    assert.equal(r.tier, "builder");
+    assert.equal(r.toolHeavy, true);
+  });
+
+  it("implement + curl + api → builder, toolHeavy=true", () => {
+    const r = classifyPrompt("implement a curl wrapper for the payments API");
+    assert.equal(r.kind, "implementation");
+    assert.equal(r.tier, "builder");
+    assert.equal(r.toolHeavy, true);
+  });
+
+  it("build + agent keyword → builder (tool escalates complexity but not to reasoning on its own)", () => {
+    const r = classifyPrompt("build a function that calls an agent");
+    assert.equal(r.kind, "implementation");
+    assert.equal(r.tier, "builder");
+    assert.equal(r.toolHeavy, true);
+  });
+
+  it("pure light implement (show/list + no complexity) → economy", () => {
+    // "list" is both a LIGHT_KEYWORD and overlaps with IMPLEMENT (via "find" which isn't impl)
+    // "show" is light — combined with zero complexity should stay economy
+    const r = classifyPrompt("show me what to add");
+    // "show" → light, "add" → implement; but LIGHT_KEYWORDS wins when complexity=0
+    assert.equal(r.tier, "economy");
+  });
+});
+
+// ---------------------------------------------------------------------------
+// classifyPrompt — orchestration escalation → reasoning tier
+// ---------------------------------------------------------------------------
+describe("classifyPrompt: orchestration escalation", () => {
+  it("implement + parallel agents → reasoning", () => {
+    const r = classifyPrompt(
+      "implement a workflow using parallel agents to process each repository",
+    );
+    assert.equal(r.kind, "implementation");
+    assert.equal(r.tier, "reasoning");
+  });
+
+  it("implement + orchestrate → reasoning", () => {
+    const r = classifyPrompt("implement and orchestrate the multi-step deployment pipeline");
+    assert.equal(r.kind, "implementation");
+    assert.equal(r.tier, "reasoning");
+  });
+
+  it("implement + tool chain → reasoning", () => {
+    const r = classifyPrompt("build a tool chain that lints, tests, and deploys");
+    assert.equal(r.kind, "implementation");
+    assert.equal(r.tier, "reasoning");
+  });
+
+  it("implement + chained tools → reasoning", () => {
+    const r = classifyPrompt("write a script using chained tools to process the data");
+    assert.equal(r.kind, "implementation");
+    assert.equal(r.tier, "reasoning");
+  });
+
+  it("general prompt + orchestration → reasoning", () => {
+    const r = classifyPrompt(
+      "set up multi-agent orchestration for the analytics pipeline",
+    );
+    // "set up" isn't an implement keyword, but orchestration escalates general→reasoning
+    assert.equal(r.tier, "reasoning");
+  });
+
+  it("plain implement WITHOUT orchestration stays builder", () => {
+    const r = classifyPrompt("implement a retry mechanism for failed HTTP requests");
+    assert.equal(r.tier, "builder");
+  });
+});
+
+// ---------------------------------------------------------------------------
+// classifyPrompt — misc tier boundaries
+// ---------------------------------------------------------------------------
+describe("classifyPrompt: tier boundaries", () => {
+  it("plain question → lightweight, economy", () => {
+    const r = classifyPrompt("what is dependency injection?");
+    assert.equal(r.kind, "lightweight");
+    assert.equal(r.tier, "economy");
+  });
+
+  it("debug keyword alone → debugging, builder (low complexity)", () => {
+    const r = classifyPrompt("debug the login crash");
+    assert.equal(r.kind, "debugging");
+    assert.equal(r.tier, "builder");
+  });
+
+  it("plan keyword alone → planning, builder (low complexity)", () => {
+    const r = classifyPrompt("plan the database migration");
+    assert.equal(r.kind, "planning");
+    assert.equal(r.tier, "builder");
+  });
+
+  it("review always wins over planning keyword in same prompt", () => {
+    const r = classifyPrompt("review and plan the architecture changes");
+    assert.equal(r.kind, "review");
+    assert.equal(r.tier, "reasoning");
+  });
+});
