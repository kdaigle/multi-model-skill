+++ b/tests/classify.test.mjs
@@ -0,0 +1,261 @@
+// Regression tests for prompt-classification heuristics in the model-router extension.
+// Uses only Node built-ins: node:test + node:assert.
+// Run with: node --test tests/classify.test.mjs
+
+import { describe, it } from "node:test";
+import assert from "node:assert/strict";
+import {
+  classifyPrompt,
+  isExplicitReviewRequest,
+  isToolHeavy,
+  isComplexOrchestration,
+  matchesPattern,
+  normalizePrompt,
+} from "../.github/extensions/model-router/classify.mjs";
+
+// ---------------------------------------------------------------------------
+// 1. Explicit review detection
+// ---------------------------------------------------------------------------
+
+describe("isExplicitReviewRequest", () => {
+  it("detects bare 'review'", () => {
+    assert.ok(isExplicitReviewRequest("review my implementation"));
+  });
+
+  it("detects 'code review'", () => {
+    assert.ok(isExplicitReviewRequest("do a code review of this PR"));
+  });
+
+  it("detects 'audit'", () => {
+    assert.ok(isExplicitReviewRequest("audit the authentication module"));
+  });
+
+  it("detects 'pr review'", () => {
+    assert.ok(isExplicitReviewRequest("PR review for the new feature branch"));
+  });
+
+  it("detects 'find bugs'", () => {
+    assert.ok(isExplicitReviewRequest("find bugs in the payment service"));
+  });
+
+  it("detects 'regression hunt'", () => {
+    assert.ok(isExplicitReviewRequest("regression hunt the recent deploy"));
+  });
+
+  it("detects 'find regressions'", () => {
+    assert.ok(isExplicitReviewRequest("find regressions introduced in the last release"));
+  });
+
+  it("detects 'approval readiness'", () => {
+    assert.ok(isExplicitReviewRequest("approval readiness checks for the security feature"));
+  });
+
+  it("does not match non-review prompts", () => {
+    assert.ok(!isExplicitReviewRequest("implement a new endpoint"));
+    assert.ok(!isExplicitReviewRequest("build a bash script to run tests"));
+    assert.ok(!isExplicitReviewRequest("explain how the router works"));
+  });
+});
+
+describe("classifyPrompt – explicit review → reasoning tier", () => {
+  it("maps 'review my code' to kind=review, tier=reasoning", () => {
+    const result = classifyPrompt("review my code");
+    assert.equal(result.kind, "review");
+    assert.equal(result.tier, "reasoning");
+  });
+
+  it("maps 'audit the codebase' to kind=review, tier=reasoning", () => {
+    const result = classifyPrompt("audit the codebase for security issues");
+    assert.equal(result.kind, "review");
+    assert.equal(result.tier, "reasoning");
+  });
+
+  it("maps 'find bugs in the login flow' to kind=review, tier=reasoning", () => {
+    const result = classifyPrompt("find bugs in the login flow");
+    assert.equal(result.kind, "review");
+    assert.equal(result.tier, "reasoning");
+  });
+
+  it("review classification wins over implementation keywords in the same prompt", () => {
+    // "review" takes priority over "implement" because it's checked first
+    const result = classifyPrompt("review and implement the missing tests");
+    assert.equal(result.kind, "review");
+    assert.equal(result.tier, "reasoning");
+  });
+});
+
+// ---------------------------------------------------------------------------
+// 2. Tool-heavy implementation routing
+// ---------------------------------------------------------------------------
+
+describe("isToolHeavy", () => {
+  it("detects 'bash'", () => {
+    assert.ok(isToolHeavy("write a bash script to deploy the app"));
+  });
+
+  it("detects 'curl'", () => {
+    assert.ok(isToolHeavy("use curl to fetch the remote API"));
+  });
+
+  it("detects 'execute'", () => {
+    assert.ok(isToolHeavy("execute the migration script"));
+  });
+
+  it("detects 'script'", () => {
+    assert.ok(isToolHeavy("create a script that runs the test suite"));
+  });
+
+  it("detects 'api'", () => {
+    assert.ok(isToolHeavy("build an api wrapper for the service"));
+  });
+
+  it("detects 'shell'", () => {
+    assert.ok(isToolHeavy("invoke the shell command to restart the server"));
+  });
+
+  it("does not match unrelated prompts", () => {
+    assert.ok(!isToolHeavy("explain the architecture design"));
+    assert.ok(!isToolHeavy("summarize the recent changes"));
+  });
+});
+
+describe("classifyPrompt – tool-heavy implementation → builder tier, toolHeavy flag", () => {
+  it("sets toolHeavy=true for prompts with tool keywords", () => {
+    const result = classifyPrompt("implement a bash script to run the test suite");
+    assert.equal(result.kind, "implementation");
+    assert.equal(result.toolHeavy, true);
+  });
+
+  it("routes tool-heavy implementation to at least builder tier", () => {
+    const result = classifyPrompt("build an api endpoint that handles user authentication");
+    assert.equal(result.kind, "implementation");
+    assert.ok(
+      result.tier === "builder" || result.tier === "reasoning",
+      `expected builder or reasoning tier, got ${result.tier}`
+    );
+  });
+
+  it("sets toolHeavy=false when no tool keywords present", () => {
+    const result = classifyPrompt("implement a sorting algorithm");
+    assert.equal(result.kind, "implementation");
+    assert.equal(result.toolHeavy, false);
+  });
+
+  it("tool-heavy general (non-impl) prompts escalate beyond economy at complexity>=1", () => {
+    // "run the http request" is not an implement keyword, but has tool keywords
+    const result = classifyPrompt("run the http request against the staging endpoint and check the response");
+    assert.ok(
+      result.tier === "builder" || result.tier === "reasoning",
+      `expected builder or reasoning tier, got ${result.tier}`
+    );
+  });
+});
+
+// ---------------------------------------------------------------------------
+// 3. Orchestration escalation
+// ---------------------------------------------------------------------------
+
+describe("isComplexOrchestration", () => {
+  it("detects 'parallel agents'", () => {
+    assert.ok(isComplexOrchestration("use parallel agents to process the queue"));
+  });
+
+  it("detects 'multi-agent'", () => {
+    assert.ok(isComplexOrchestration("design a multi-agent workflow"));
+  });
+
+  it("detects 'multiple agents'", () => {
+    assert.ok(isComplexOrchestration("coordinate multiple agents across the pipeline"));
+  });
+
+  it("detects 'chained tools'", () => {
+    assert.ok(isComplexOrchestration("build a pipeline using chained tools"));
+  });
+
+  it("detects 'tool chain'", () => {
+    assert.ok(isComplexOrchestration("implement a tool chain for the ETL process"));
+  });
+
+  it("detects 'parallel tools'", () => {
+    assert.ok(isComplexOrchestration("invoke parallel tools to speed up the job"));
+  });
+
+  it("does NOT match bare 'orchestration' (would cause false positives)", () => {
+    assert.ok(!isComplexOrchestration("this document describes orchestration patterns"));
+    assert.ok(!isComplexOrchestration("discuss orchestration in the architecture"));
+  });
+
+  it("does NOT match bare 'agent'", () => {
+    // 'agent' is a TOOL_KEYWORD but NOT an ORCHESTRATION_KEYWORD
+    assert.ok(!isComplexOrchestration("build an agent to handle requests"));
+  });
+});
+
+describe("classifyPrompt – orchestration escalation → reasoning tier", () => {
+  it("escalates multi-agent implementation with sufficient complexity to reasoning", () => {
+    // "multiple files" adds complexity=2; "implement" is an impl keyword; "multiple agents" triggers orchestration
+    const result = classifyPrompt(
+      "implement a system using multiple agents to process multiple files in the repository"
+    );
+    assert.equal(result.kind, "implementation");
+    assert.equal(result.tier, "reasoning");
+  });
+
+  it("escalates chained-tools implementation with multi-file complexity to reasoning", () => {
+    const result = classifyPrompt(
+      "build a pipeline using chained tools that transforms multiple files and validates end-to-end"
+    );
+    assert.equal(result.kind, "implementation");
+    assert.equal(result.tier, "reasoning");
+  });
+
+  it("does NOT escalate low-complexity orchestration mention to reasoning", () => {
+    // complexity < 2: short prompt with only the orchestration keyword → stays at builder
+    const result = classifyPrompt("implement parallel agents");
+    assert.equal(result.kind, "implementation");
+    // complexity=0 here (short, no file paths, no complexity indicators), so tier stays builder
+    assert.notEqual(result.tier, "reasoning");
+  });
+
+  it("bare 'orchestration' without multi-word phrase does not trigger escalation", () => {
+    const result = classifyPrompt("implement the orchestration layer for the workflow");
+    // "orchestration" alone is not in ORCHESTRATION_KEYWORDS → no escalation
+    assert.equal(result.kind, "implementation");
+    // Should be builder (default for impl) not reasoning
+    assert.equal(result.tier, "builder");
+  });
+});
