     const result = orderCandidates(candidates, { kind: "review" }, "claude-sonnet-4.6");
     assert.equal(result[0].id, "gpt-5.1");
   });
+
+  // Regression: broad-family diversity — a claude-opus model must NOT be ranked
+  // equally with gpt models when the last impl also used Claude. Before the fix,
+  // isSameModelFamily("claude-opus-4.5", "claude-sonnet-4.6") returned false
+  // (different sub-families), giving claude-opus a score of 0 (same as gpt),
+  // so it could be tried before gpt-5.1-codex-max or other GPT fallbacks.
+  it("deprioritises same-broad-family model (different sub-family) behind distinct-family models", () => {
+    const candidates = [
+      { id: "claude-opus-4.5", reasoningEffort: null }, // same broad family, different sub-family
+      { id: "gpt-5.1", reasoningEffort: null },          // distinct broad family
+      { id: "claude-haiku-4.5", reasoningEffort: null }, // same broad family, different sub-family
+    ];
+    const result = orderCandidates(candidates, { kind: "review" }, "claude-sonnet-4.6");
+    const gptIdx   = result.findIndex((c) => c.id === "gpt-5.1");
+    const opusIdx  = result.findIndex((c) => c.id === "claude-opus-4.5");
+    const haikuIdx = result.findIndex((c) => c.id === "claude-haiku-4.5");
+    assert.ok(gptIdx < opusIdx,  "gpt-5.1 must precede claude-opus-4.5");
+    assert.ok(gptIdx < haikuIdx, "gpt-5.1 must precede claude-haiku-4.5");
+  });
+
