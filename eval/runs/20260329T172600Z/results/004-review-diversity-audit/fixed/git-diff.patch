+      { id: "claude-sonnet-4.6", reasoningEffort: null }, // distinct family
+      { id: "gpt-5-mini", reasoningEffort: null },       // same broad family, different sub-family
+    ];
+    const result = orderCandidates(candidates, { kind: "review" }, "gpt-5.1");
+    const claudeIdx = result.findIndex((c) => c.id === "claude-sonnet-4.6");
+    const gpt54Idx  = result.findIndex((c) => c.id === "gpt-5.4");
+    const miniIdx   = result.findIndex((c) => c.id === "gpt-5-mini");
+    assert.ok(claudeIdx < gpt54Idx,  "claude-sonnet-4.6 must precede gpt-5.4");
+    assert.ok(claudeIdx < miniIdx,   "claude-sonnet-4.6 must precede gpt-5-mini");
+  });
