diff --git a/eval/routing-policy.test.mjs b/eval/routing-policy.test.mjs
index 1f264f9..1f80fe8 100644
--- a/eval/routing-policy.test.mjs
+++ b/eval/routing-policy.test.mjs
@@ -323,6 +323,24 @@ describe("isSameModelFamily", () => {
   it("returns false for null first arg", () => {
     assert.ok(!isSameModelFamily(null, "gpt-5.1"));
   });
+
+  // Regression: gpt-5.x-codex variants must be in the same "gpt-5" family as
+  // plain gpt-5.x models. The old code checked model.includes("codex") first,
+  // making gpt-5.3-codex appear as a separate "codex" family, so gpt-5 would
+  // incorrectly score 0 (different-family) when impl was a codex model.
+  it("treats gpt-5.x-codex and plain gpt-5.x as the same family", () => {
+    assert.ok(isSameModelFamily("gpt-5.3-codex", "gpt-5.1"), "codex vs plain gpt-5");
+    assert.ok(isSameModelFamily("gpt-5.1-codex", "gpt-5.4"), "codex vs gpt-5.4");
+    assert.ok(isSameModelFamily("gpt-5.1-codex-max", "gpt-5.2"), "codex-max vs gpt-5.2");
+  });
+
+  it("treats two gpt-5-codex variants as the same family", () => {
+    assert.ok(isSameModelFamily("gpt-5.3-codex", "gpt-5.1-codex"));
+  });
+
+  it("still returns false for codex vs claude", () => {
+    assert.ok(!isSameModelFamily("gpt-5.3-codex", "claude-sonnet-4.6"));
+  });
 });
 
