+    const result = orderCandidates(candidates, { kind: "review" }, "gpt-5.3-codex");
+    assert.equal(result[0].id, "claude-sonnet-4.6", `expected claude first; got: ${result.map((c) => c.id)}`);
+  });
 });
 
